                "queue"
            ],
            "properties": {
                "jobs": {
                    "type": "array",
                    "items": {
                        "type": "object"
                    }
                },
                "queue": {
                    "type": "string"
                },
                "timeout": {
                    "description": "Default timeout for all jobs",
                    "type": "integer"
                }
            }
        },
        "api.BatchTaskResponse": {
            "type": "object",
            "properties": {
                "enqueued": {
                    "type": "integer"

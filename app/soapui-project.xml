    <!-- GET /queue/{uuid}/{priority} - Get Task Status -->
    <con:resource name="GetTaskStatus" path="/queue/{uuid}/{priority}" id="2ec4b05e-204d-4a67-8880-050c40fb69d4">
      <con:settings/>
      <con:parameters>
        <con:parameter>
          <con:name>uuid</con:name>
          <con:value>example-uuid-123</con:value>
          <con:style>TEMPLATE</con:style>
          <con:default>example-uuid-123</con:default>
          <con:description>Task UUID returned from POST /queue/add</con:description>
        </con:parameter>
        <con:parameter>
          <con:name>priority</con:name>
          <con:value>normal</con:value>
          <con:style>TEMPLATE</con:style>
          <con:default>normal</con:default>
          <con:description>Queue priority: "normal" or "priority"</con:description>
        </con:parameter>
      </con:parameters>
      <con:method name="GET" id="get-task-status" method="GET">
        <con:settings/>
        <con:parameters/>
        <con:representation type="RESPONSE">
          <con:mediaType>application/json</con:mediaType>
          <con:status>200</con:status>
          <con:params/>
          <con:description>Task status and result</con:description>
          <con:sampleContent>{
  "info": {
    "id": "task-uuid",
    "type": "predict",
    "payload": "{}",
    "state": "completed",
    "queue": "normal",
    "max_retry": 3,
    "retried": 0,
    "result": "{}"
  }
}</con:sampleContent>
        </con:representation>
        <con:representation type="FAULT">
          <con:mediaType>application/json</con:mediaType>
          <con:status>400</con:status>
          <con:params/>
          <con:description>Error response</con:description>
          <con:sampleContent>{
  "errors": ["task not found"]
}</con:sampleContent>
        </con:representation>
        <con:representation type="FAULT"><con:mediaType>application/json; charset=utf-8</con:mediaType><con:status>400</con:status><con:params/><con:element xmlns:nor="http://localhost/queue/your-task-uuid-here/normal">nor:Fault</con:element></con:representation><con:request name="Get Task Status - Normal Queue" id="get-task-normal" mediaType="application/json">
          <con:settings><con:setting id="com.eviware.soapui.impl.wsdl.WsdlRequest@request-headers">&lt;xml-fragment/></con:setting></con:settings>
          <con:endpoint>http://localhost:3000</con:endpoint>
          <con:request/><con:originalUri>http://localhost/queue/your-task-uuid-here/normal</con:originalUri><con:credentials><con:authType>No Authorization</con:authType></con:credentials><con:jmsConfig JMSDeliveryMode="PERSISTENT"/><con:jmsPropertyConfig/><con:parameters>
            <con:entry key="uuid" value="your-task-uuid-here"/>
            <con:entry key="priority" value="normal"/>
          </con:parameters>
        </con:request>
        <con:request name="Get Task Status - Priority Queue" id="get-task-priority" mediaType="application/json">
          <con:settings/>
          <con:endpoint>http://localhost:3000</con:endpoint>
          <con:parameters>
            <con:entry key="uuid" value="your-task-uuid-here"/>
            <con:entry key="priority" value="priority"/>
          </con:parameters>
        </con:request>
      </con:method>
    </con:resource>

    <!-- POST /queue/add - Add New Task -->
    <con:resource name="AddTask" path="/queue/add" id="b09a600f-e7f8-4b3b-8b6a-2fb38b9341cb">
      <con:settings/>
      <con:parameters/>
      <con:method name="POST" id="add-task" method="POST">
        <con:settings/>
        <con:parameters/>
        <con:representation type="REQUEST">
          <con:mediaType>application/json</con:mediaType>
          <con:params/>
          <con:description>Prediction request body</con:description>
          <con:sampleContent>{
  "user_id": 1,
  "predict_id": 1,
  "queue": "normal",
  "timeout": 300,
  "provider": "worker",
  "webhook_url": "https://example.com/webhook",
  "model_input": {
    "prompt": "A futuristic cityscape at sunset",
    "width": 1024,
    "height": 1024,
    "num_steps": 20,
    "guidance_scale": 7.5,
    "batch_nbr": 1,
    "model_name": "illustrious-hassuka-xl"
  }
}</con:sampleContent>
        </con:representation>
        <con:representation type="RESPONSE">
          <con:mediaType>application/json</con:mediaType>
          <con:status>200</con:status>
          <con:params/>
          <con:description>Task enqueued successfully</con:description>
          <con:sampleContent>{
  "info": {
    "id": "generated-task-uuid",
    "type": "predict",
    "state": "pending",
    "queue": "normal"
  },
  "user_predict": {}
}</con:sampleContent>
        </con:representation>
        <con:representation type="FAULT">
          <con:mediaType>application/json</con:mediaType>
          <con:status>401</con:status>
          <con:params/>
          <con:description>Unauthorized</con:description>
          <con:sampleContent>{
  "errors": ["access unauthorized"]
}</con:sampleContent>
        </con:representation>


FROM alpine:3.19

# Install ca-certificates for HTTPS
RUN apk add --no-cache ca-certificates

# Create non-root user
RUN adduser -D -h /app runqy
USER runqy
WORKDIR /app

# Copy pre-built binary from GoReleaser context
ARG TARGETPLATFORM
COPY ${TARGETPLATFORM}/runqy /usr/local/bin/runqy

EXPOSE 3000

ENTRYPOINT ["runqy"]
CMD ["serve"]
